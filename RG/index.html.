<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Registration Form</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --bg-1:#0F0B1F;
    --bg-2:#1B1338;
    --card:rgba(255,255,255,0.045);
    --card-border:rgba(255,255,255,0.09);
    --violet:#8B5CF6;
    --violet-dark:#5B21B6;
    --gold:#F5B942;
    --text-main:#F3F1FA;
    --text-muted:#A79ECB;
    --danger:#FF6B6B;
    --success:#4ADE80;
  }

  *{box-sizing:border-box; margin:0; padding:0;}

  body{
    min-height:100vh;
    font-family:'Inter', sans-serif;
    color:var(--text-main);
    background:
      radial-gradient(circle at 15% 20%, rgba(139,92,246,0.25), transparent 40%),
      radial-gradient(circle at 85% 80%, rgba(245,185,66,0.12), transparent 45%),
      linear-gradient(160deg, var(--bg-1), var(--bg-2));
    background-attachment:fixed;
    display:flex;
    align-items:center;
    justify-content:center;
    padding:40px 16px;
  }

  .wrapper{
    width:100%;
    max-width:520px;
  }

  .eyebrow{
    display:flex;
    align-items:center;
    gap:10px;
    justify-content:center;
    margin-bottom:14px;
  }

  .eyebrow span{
    height:1px;
    width:32px;
    background:linear-gradient(90deg, transparent, var(--gold));
  }

  .eyebrow span.right{
    background:linear-gradient(90deg, var(--gold), transparent);
  }

  .eyebrow p{
    font-size:12px;
    letter-spacing:3px;
    text-transform:uppercase;
    color:var(--gold);
    font-weight:600;
  }

  h1{
    font-family:'Sora', sans-serif;
    font-size:32px;
    font-weight:800;
    text-align:center;
    letter-spacing:-0.5px;
    background:linear-gradient(90deg, #fff, #C9BBF5);
    -webkit-background-clip:text;
    background-clip:text;
    color:transparent;
  }

  .subtitle{
    text-align:center;
    color:var(--text-muted);
    font-size:14px;
    margin-top:6px;
    margin-bottom:32px;
  }

  form{
    background:var(--card);
    border:1px solid var(--card-border);
    backdrop-filter:blur(18px);
    -webkit-backdrop-filter:blur(18px);
    border-radius:20px;
    padding:36px 32px;
    box-shadow:0 20px 60px rgba(0,0,0,0.45), inset 0 1px 0 rgba(255,255,255,0.05);
  }

  .field{
    margin-bottom:22px;
    position:relative;
  }

  .field label{
    display:block;
    font-size:13px;
    font-weight:600;
    color:var(--text-muted);
    margin-bottom:8px;
    letter-spacing:0.3px;
  }

  .input-shell{
    position:relative;
    display:flex;
    align-items:center;
  }

  .input-shell svg{
    position:absolute;
    left:14px;
    width:17px;
    height:17px;
    stroke:var(--text-muted);
    pointer-events:none;
  }

  input[type="text"],
  input[type="email"],
  input[type="password"],
  select{
    width:100%;
    padding:13px 14px 13px 42px;
    background:rgba(255,255,255,0.04);
    border:1px solid rgba(255,255,255,0.09);
    border-radius:12px;
    color:var(--text-main);
    font-size:14.5px;
    font-family:'Inter', sans-serif;
    outline:none;
    transition:border-color .2s ease, box-shadow .2s ease, background .2s ease;
  }

  input::placeholder{
    color:#6E6591;
  }

  input:focus,
  select:focus{
    border-color:var(--violet);
    background:rgba(139,92,246,0.08);
    box-shadow:0 0 0 4px rgba(139,92,246,0.15);
  }

  select{
    padding-left:14px;
    appearance:none;
    -webkit-appearance:none;
    background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='%23A79ECB' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'/></svg>");
    background-repeat:no-repeat;
    background-position:right 14px center;
    cursor:pointer;
  }

  select option{
    background:#1B1338;
    color:var(--text-main);
  }

  /* Password strength meter */
  .strength-meter{
    display:flex;
    gap:6px;
    margin-top:10px;
  }

  .strength-meter span{
    height:4px;
    flex:1;
    border-radius:3px;
    background:rgba(255,255,255,0.09);
    transition:background .25s ease;
  }

  .strength-label{
    font-size:11.5px;
    margin-top:7px;
    color:var(--text-muted);
    letter-spacing:0.3px;
  }

  /* Gender pills */
  .gender-group{
    display:flex;
    gap:10px;
    flex-wrap:wrap;
  }

  .gender-group input[type="radio"]{
    display:none;
  }

  .gender-group label{
    margin:0;
    flex:1;
    text-align:center;
    padding:11px 10px;
    border-radius:12px;
    border:1px solid rgba(255,255,255,0.09);
    background:rgba(255,255,255,0.03);
    color:var(--text-muted);
    font-size:13.5px;
    font-weight:500;
    cursor:pointer;
    transition:all .2s ease;
    min-width:90px;
  }

  .gender-group input[type="radio"]:checked + label{
    background:linear-gradient(135deg, var(--violet), var(--violet-dark));
    border-color:var(--violet);
    color:#fff;
    box-shadow:0 6px 18px rgba(139,92,246,0.35);
  }

  .gender-group label:hover{
    border-color:var(--violet);
  }

  button[type="submit"]{
    width:100%;
    margin-top:8px;
    padding:15px;
    border:none;
    border-radius:12px;
    background:linear-gradient(135deg, var(--gold), #E29B1A);
    color:#241705;
    font-size:15.5px;
    font-weight:700;
    letter-spacing:0.3px;
    cursor:pointer;
    transition:transform .18s ease, box-shadow .18s ease;
    box-shadow:0 10px 30px rgba(245,185,66,0.25);
  }

  button[type="submit"]:hover{
    transform:translateY(-2px);
    box-shadow:0 14px 36px rgba(245,185,66,0.4);
  }

  button[type="submit"]:active{
    transform:translateY(0);
  }

  button[type="submit"]:focus-visible,
  input:focus-visible,
  select:focus-visible,
  .gender-group label:focus-visible{
    outline:2px solid var(--gold);
    outline-offset:2px;
  }

  footer{
    text-align:center;
    color:var(--text-muted);
    font-size:12px;
    margin-top:22px;
    letter-spacing:0.3px;
  }

  @media (max-width:480px){
    form{ padding:28px 20px; }
    h1{ font-size:26px; }
    .gender-group{ flex-direction:column; }
  }

  @media (prefers-reduced-motion: reduce){
    *{ transition:none !important; }
  }
</style>
</head>
<body>

  <div class="wrapper">

    <div class="eyebrow">
      <span></span>
      <p>Satic &middot; Week 1</p>
      <span class="right"></span>
    </div>

    <h1>Create Your Account</h1>
    <p class="subtitle">Fill in your details to complete registration</p>

    <form action="#" method="post" novalidate>

      <!-- Full Name -->
      <div class="field">
        <label for="fullname">Full Name</label>
        <div class="input-shell">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <input type="text" id="fullname" name="fullname" placeholder="Enter your full name" required>
        </div>
      </div>

      <!-- Email -->
      <div class="field">
        <label for="email">Email Address</label>
        <div class="input-shell">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 6-10 7L2 6"/></svg>
          <input type="email" id="email" name="email" placeholder="you@example.com" required>
        </div>
      </div>

      <!-- Password -->
      <div class="field">
        <label for="password">Password</label>
        <div class="input-shell">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          <input type="password" id="password" name="password" placeholder="Create a strong password" required oninput="updateStrength(this.value)">
        </div>
        <div class="strength-meter">
          <span id="bar1"></span>
          <span id="bar2"></span>
          <span id="bar3"></span>
          <span id="bar4"></span>
        </div>
        <p class="strength-label" id="strengthLabel">Password strength</p>
      </div>

      <!-- Gender -->
      <div class="field">
        <label>Gender</label>
        <div class="gender-group">
          <input type="radio" id="male" name="gender" value="male">
          <label for="male">Male</label>

          <input type="radio" id="female" name="gender" value="female">
          <label for="female">Female</label>

          <input type="radio" id="other" name="gender" value="other">
          <label for="other">Other</label>
        </div>
      </div>

      <!-- Course / Interest -->
      <div class="field">
        <label for="course">Course / Interest</label>
        <select id="course" name="course">
          <option value="">Select Course / Interest</option>
          <option value="frontend">Frontend Development</option>
          <option value="backend">Backend Development</option>
          <option value="fullstack">Full Stack Development</option>
          <option value="datascience">Data Science</option>
          <option value="uiux">UI/UX Design</option>
        </select>
      </div>

      <!-- Submit -->
      <button type="submit">Submit Registration</button>

    </form>

    <footer>&copy; 2026 Satic &middot; Frontend Development Internship</footer>

  </div>

<script>
  function updateStrength(value){
    const bars = [document.getElementById('bar1'), document.getElementById('bar2'), document.getElementById('bar3'), document.getElementById('bar4')];
    const label = document.getElementById('strengthLabel');
    let score = 0;

    if(value.length >= 6) score++;
    if(value.length >= 10) score++;
    if(/[A-Z]/.test(value) && /[0-9]/.test(value)) score++;
    if(/[^A-Za-z0-9]/.test(value)) score++;

    const colors = ['#FF6B6B', '#FF6B6B', '#F5B942', '#4ADE80'];
    const labels = ['Weak', 'Weak', 'Fair', 'Good', 'Strong'];

    bars.forEach((bar, i) => {
      bar.style.background = i < score ? colors[Math.min(score-1,3)] : 'rgba(255,255,255,0.09)';
    });

    label.textContent = value.length === 0 ? 'Password strength' : labels[score];
    label.style.color = value.length === 0 ? 'var(--text-muted)' : colors[Math.min(score-1,3)] || 'var(--text-muted)';
  }
</script>

</body>
</html>
